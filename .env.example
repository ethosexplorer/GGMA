# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Calendly Personal Access Token — get it from:
# https://calendly.com/integrations/api_webhooks
VITE_CALENDLY_TOKEN="YOUR_CALENDLY_PERSONAL_ACCESS_TOKEN"
VITE_CALENDLY_EVENT_TYPE="https://api.calendly.com/event_types/YOUR_EVENT_TYPE_ID"

# 800.com VoIP Integration
VITE_VOIP_800_TOKEN="YOUR_800_COM_TOKEN"

# Carepatron Telehealth & eRx Integration
CAREPATRON_EMAIL="YOUR_CAREPATRON_EMAIL"
CAREPATRON_PASS="YOUR_CAREPATRON_PASS"

# Google Calendar Synchronization (Carepatron Workaround)
MASTER_CALENDAR_EMAIL="YOUR_MASTER_CALENDAR_EMAIL"
SUPPORT_CALENDAR_EMAIL="YOUR_SUPPORT_CALENDAR_EMAIL"

# TextBelt SMS API Key
TEXTBELT_API_KEY="YOUR_TEXTBELT_API_KEY"

# Marketing Campaign SMTP
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="marketing@yourdomain.com"
SMTP_PASS="YOUR_SMTP_PASSWORD"
SMTP_FROM_EMAIL="\"Global Green Enterprise\" <marketing@yourdomain.com>"
VITE_SMTP_FROM_EMAIL="\"Global Green Enterprise\" <marketing@yourdomain.com>"

# Gmail IMAP inbox reading (Marketing inbox)
GMAIL_MARKETING_EMAIL="marketing@yourdomain.com"
GMAIL_MARKETING_APP_PASSWORD="YOUR_GMAIL_APP_PASSWORD"

# Founder Personal Inbox IMAP (daily email in dashboard webmail)
FOUNDER_EMAIL="founder@yourdomain.com"
FOUNDER_APP_PASSWORD="YOUR_FOUNDER_APP_PASSWORD"
