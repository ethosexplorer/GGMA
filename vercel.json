{
  "buildCommand": "vite build",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 120
    }
  },
  "rewrites": [
    { "source": "/api/twilio/:path*", "destination": "/api/twilio.js?__endpoint=:path*" },
    { "source": "/api/send-sms", "destination": "/api/twilio.js?__endpoint=send-sms" },
    { "source": "/api/gemini-stream", "destination": "/api/gemini.js?stream=true" },
    { "source": "/api/paypal-webhook", "destination": "/api/webhook.js?type=paypal" },
    { "source": "/api/calendly-webhook", "destination": "/api/webhook.js?type=calendly" },
    { "source": "/api/freemius-webhook", "destination": "/api/webhook.js?type=freemius" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
